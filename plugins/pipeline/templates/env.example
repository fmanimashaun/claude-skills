# ─────────────────────────────────────────────────────────────────────────────
# .env — DEPLOYMENT BRIEFING SHEET for /pipeline:deploy-cloud
#
# This is NOT a Rails runtime file. Rails 8 uses encrypted credentials, not dotenv.
# This file is the single source of truth the deploy AGENT reads so it never has to
# prompt you for a value. The agent ROUTES each key below to its Rails-native home.
#
# Copy to `.env` and fill in real values. NEVER commit `.env` (it is gitignored).
# Each section is tagged with where the agent will put the value.
# ─────────────────────────────────────────────────────────────────────────────

# ═══ ROUTED TO: config/deploy.yml  (non-secret deploy facts) ═════════════════
REGISTRY_USER=your-github-username          # ghcr.io username (registry.username)
IMAGE=ghcr.io/your-org/your-app             # container image path
WEB_HOST=203.0.113.10                       # target server public IP or DNS (servers.web)
APP_HOST=app.example.com                    # domain for SSL (proxy.host — Kamal auto-cert)
DEPLOY_DESTINATION=production               # optional: names .kamal/secrets.<dest>

# ═══ ROUTED TO: .kamal/secrets  (gitignored; deploy-time secrets, by NAME in deploy.yml) ═
KAMAL_REGISTRY_PASSWORD=ghp_xxxxxxxxxxxx     # GitHub PAT, scope: write:packages
RAILS_MASTER_KEY=                            # from config/credentials/production.key
POSTGRES_PASSWORD=change-me                  # if using the self-hosted Postgres accessory

# ═══ ROUTED TO: Rails encrypted credentials  (production.yml.enc, image-baked) ═══
# App runtime secrets the running app reads. The agent writes these NON-INTERACTIVELY
# into encrypted credentials (committed as ciphertext; decrypts only with the master
# key). Add one line per secret your app needs. Examples — replace with yours:
CRED__secret_key_base=                       # leave blank to let the agent generate one
# CRED__stripe__api_key=sk_live_xxx          # nested: CRED__<top>__<sub> → stripe: { api_key: }
# CRED__aws__access_key_id=
# CRED__aws__secret_access_key=
# CRED__smtp__password=

# ═══ ROUTED TO: config/deploy.yml env.clear  (non-secret runtime config) ═════
RAILS_ENV=production
# RAILS_LOG_TO_STDOUT=1
# any non-secret runtime toggles your app reads from ENV
